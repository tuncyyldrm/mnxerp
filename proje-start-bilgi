USE ONEDB;
GO

-- 1. ESKİ/FAZLA İNDEKSLERİ TEMİZLE (Çakışmaları önlemek için)
-- IX_Stok_Filtre zaten IX_Stok_Arama'nın içinde var, siliyoruz.
IF EXISTS (SELECT * FROM sys.indexes WHERE name = 'IX_Stok_Filtre' AND object_id = OBJECT_ID('stok'))
    DROP INDEX IX_Stok_Filtre ON [stok];
GO

-- 2. ANA FİLTRE VE LİSTELEME İNDEKSİ (Kategori ve Grup Seçimleri İçin)
-- INCLUDE kısmına 'Raf' eklendi, böylece liste ekranında SQL ana tabloya hiç gitmez.
IF EXISTS (SELECT * FROM sys.indexes WHERE name = 'IX_Stok_Arama' AND object_id = OBJECT_ID('stok'))
    DROP INDEX IX_Stok_Arama ON [stok];

CREATE NONCLUSTERED INDEX IX_Stok_Filtreleme_Master
ON [dbo].[stok] (grubu, kateGOri, tipi) 
INCLUDE (urunkodu, urun, fiyatı, STK_FULL, Raf); 
GO

-- 3. ÜRÜN İSMİ ARAMA İNDEKSİ (Arama Kutusu İçin)
-- Kullanıcı parça ismi yazdığında (LIKE 'fren%') sistemi uçuran budur.
IF NOT EXISTS (SELECT * FROM sys.indexes WHERE name = 'IX_Stok_Urun_Arama' AND object_id = OBJECT_ID('stok'))
CREATE NONCLUSTERED INDEX IX_Stok_Urun_Arama 
ON [dbo].[stok] (urun) 
INCLUDE (urunkodu, fiyatı, STK_FULL, Raf, grubu);
GO

-- 4. ÜRÜN KODU İNDEKSİ (Tam Eşleşme İçin)
-- Kod aramaları benzersiz olduğu için en hızlı sonucu bu verir.
IF NOT EXISTS (SELECT * FROM sys.indexes WHERE name = 'IX_Stok_Kod' AND object_id = OBJECT_ID('stok'))
CREATE NONCLUSTERED INDEX IX_Stok_Kod ON [stok] (urunkodu);
GO

-- 5. İSTATİSTİKLERİ GÜNCELLE (SQL'in yeni indeksleri tanıması için)
UPDATE STATISTICS [stok];
GO

